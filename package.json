{
  "name": "welix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true});\" && next dev",
    "build": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true});\" && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "node -e \"require('node:fs').rmSync('tsconfig.tsbuildinfo',{force:true});\" && next typegen && tsc --noEmit --incremental false -p tsconfig.typecheck.json",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.59.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.80.10",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.20.0",
    "next": "15.5.12",
    "next-themes": "^0.4.6",
    "openai": "^6.44.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5",
    "vite": "^7.0.6",
    "vitest": "^3.2.4"
  }
}
